{
  "name": "astroknot",
  "version": "1.0.0",
  "description": "3D 知识网络可视化与编辑工具 — 将知识节点以星图形式呈现，支持富文本编辑、多媒体嵌入、思维导图",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac --x64",
    "build:linux": "electron-builder --linux --x64",
    "rebuild": "electron-rebuild -f -w node-pty",
    "postinstall": "node scripts/copy-xterm.js && electron-builder install-app-deps",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "knowledge-graph",
    "mind-map",
    "3d-visualization",
    "note-taking",
    "electron",
    "threejs",
    "knowledge-management",
    "rich-text-editor"
  ],
  "author": {
    "name": "星移三秋",
    "email": "your.email@example.com"
  },
  "homepage": "https://gitee.com/星移三秋/astroknot",
  "license": "ISC",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/星移三秋/astroknot"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.1.0",
    "electron": "^29.4.6",
    "electron-builder": "^26.8.1",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "com.astroknot.app",
    "productName": "AstroKnot",
    "icon": "assets/icon.png",
    "buildDependenciesFromSource": false,
    "npmRebuild": false,
    "asarUnpack": [
      "node_modules/node-pty/**"
    ],
    "files": [
      "**/*",
      "!modules/StressTest.js",
      "!modules/hot-update.js",
      "!README.md",
      "!LICENSE",
      "!package-lock.json",
      "!.gitignore",
      "!.npmrc",
      "!.github/**/*",
      "!.trae/**/*",
      "!.trae-cn/**/*",
      "!AstroKnot-Data/**/*",
      "!AstroKnot文件/**/*",
      "!generated-images/**/*",
      "!web_version/**/*",
      "!official_website/**/*",
      "!scripts/**/*",
      "!tests/**/*",
      "!vitest.config.js",
      "!build-with-mirror.ps1",
      "!dist-web/**/*",
      "!dist/**/*",
      "!startAstroKnot-*.sh",
      "!startAstroKnot-*.vbs",
      "!startAstroKnot-*.command",
      "!AstroKnot-*.command",
      "!AstroKnot-*.desktop",
      "!AstroKnot-*.lnk"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.productivity",
      "files": [
        "!icon.ico"
      ]
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Education;Productivity",
      "maintainer": "星移三秋 <your.email@example.com>",
      "files": [
        "!icon.ico"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@opencode-ai/sdk": "^1.17.20",
    "@soundtouchjs/audio-worklet": "^2.0.3",
    "@univerjs/preset-sheets-advanced": "^0.25.0",
    "@univerjs/preset-sheets-conditional-formatting": "^0.25.0",
    "@univerjs/preset-sheets-core": "^0.25.0",
    "@univerjs/preset-sheets-data-validation": "^0.25.0",
    "@univerjs/preset-sheets-drawing": "^0.25.0",
    "@univerjs/preset-sheets-filter": "^0.25.0",
    "@univerjs/preset-sheets-find-replace": "^0.25.0",
    "@univerjs/preset-sheets-hyper-link": "^0.25.0",
    "@univerjs/preset-sheets-sort": "^0.25.0",
    "@univerjs/preset-sheets-thread-comment": "^0.25.0",
    "@univerjs/presets": "^0.25.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "docx-preview": "^0.3.7",
    "jszip": "^3.10.1",
    "lunar-javascript": "^1.7.7",
    "node-pty": "^1.1.0",
    "pdfjs-dist": "^6.0.227",
    "three": "^0.128.0",
    "tinymce": "^7.9.3",
    "wavesurfer.js": "^7.12.7"
  }
}
