#!/bin/bash
# ============================================================
#  AstroKnot macOS 快捷方式 (.command 文件)
#  双击即可启动，无需终端命令
# ============================================================

# 获取脚本所在目录
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

# 切换到项目目录
cd "$SCRIPT_DIR"

# 启动应用
npm start